{
  "extends": "next/core-web-vitals",
  "rules": {
    "react/no-unescaped-entities": "error",
    "@typescript-eslint/no-explicit-any": "error",
    "prefer-const": "error",
    "@typescript-eslint/no-unused-vars": ["error", { 
      "argsIgnorePattern": "^_", 
      "varsIgnorePattern": "^_",
      "args": "after-used",
      "ignoreRestSiblings": true
    }]
  }
}
