# Infrastructure
QDRANT_URL=http://localhost:6333
QDRANT_TIMEOUT_MS=2500
QDRANT_CHECK_COMPATIBILITY=false

# RAG Logic
ARIA_MODE=mock
ARIA_LLM_PROVIDER=mock
ARIA_RERANK_PROVIDER=none

# Security (Required in production)
SALT=votre-grain-de-sel-de-32-caracteres-minimum

# API Keys (Required for RAG provider !== mock)
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-...

# Server
PORT=3000
NODE_ENV=development
